# Copie para deploy/rubinot.env e preencha. NÃO comite este arquivo.
#
# Connection string do Supabase (pooler, IPv4 — funciona em qualquer VPS).
# Pegue em: Supabase > Project > Connect > "Session pooler" (porta 5432).
DATABASE_URL=postgresql://postgres.<ref>:[YOUR-PASSWORD]@aws-1-<region>.pooler.supabase.com:5432/postgres

# Alternativa (se preferir a API REST em vez do Postgres direto):
# SUPABASE_URL=https://<ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
