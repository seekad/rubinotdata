# --- Site (Next.js / Vercel) ---
# Conexão com o Supabase via pooler. Use o "Transaction pooler" (porta 6543)
# para serverless/Vercel. Supabase > Project > Connect.
DATABASE_URL=postgresql://postgres.<ref>:[YOUR-PASSWORD]@aws-1-<region>.pooler.supabase.com:6543/postgres

# Alternativa: cliente supabase-js com a chave anon (RLS de leitura pública).
# NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# --- Scraper (VPS) — ver deploy/rubinot.env.example ---
# DATABASE_URL com "Session pooler" (porta 5432).
